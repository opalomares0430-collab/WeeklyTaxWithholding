STAR

    	 DECLARE income as double
    	 DECLARE taxRate as double
    	 DECLARE taxWithheld as double
    	
    	 DISPLAY "Enter weekly income:"
    	 READ income
    	
    	 IF income < 500
             taxRate = 0.10
         ELSE IF income >= 500 AND income < 1500
             taxRate = 0.15
         ELSE IF income >= 1500 AND income < 2500
             taxRate = 0.20
         ELSE
             taxRate = 0.30
         END IF

    	 taxWithheld = income * taxRate
    	
    	 DISPLAY "Weekly Income: $" + income
    	 DISPLAY "Tax Rate: " + (taxRate * 100) + "%"
    	 DISPLAY "Weekly Tax Withheld: $" + taxWithheld
    	
    	 END
